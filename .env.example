# --- Email (Resend) ---
# Without these the site runs fully on localhost; enquiries are stored in
# data/enquiries.json and emails are skipped (logged to the console instead).

# API key from https://resend.com/api-keys
RESEND_API_KEY=

# Verified sender. Until a domain is verified in Resend you can use the
# sandbox sender: "Proofit <onboarding@resend.dev>"
RESEND_FROM="Proofit <onboarding@resend.dev>"

# Where team notifications for new enquiries go
ENQUIRY_INBOX=info@proofitcompany.com

# --- SEO ---
# Canonical URL used in sitemap/OG tags (defaults to https://www.proofitcompany.com)
NEXT_PUBLIC_SITE_URL=
